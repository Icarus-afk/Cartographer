{
  "name": "cartographer",
  "displayName": "Cartographer",
  "description": "Repository intelligence — explore any codebase as a navigable knowledge graph",
  "version": "0.1.0",
  "publisher": "cartographer",
  "license": "MIT",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Programming Languages", "Visualization", "Debuggers"],
  "repository": { "type": "git", "url": "https://github.com/Icarus-afk/Cartographer.git" },
  "icon": "",
  "activationEvents": ["onLanguage:plaintext", "onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "cartographer.index", "title": "Cartographer: Index Repository", "icon": "$(database)" },
      { "command": "cartographer.search", "title": "Cartographer: Search Graph", "icon": "$(search)" },
      { "command": "cartographer.ask", "title": "Cartographer: Ask a Question", "icon": "$(question)" },
      { "command": "cartographer.summarize", "title": "Cartographer: Repository Summary", "icon": "$(report)" },
      { "command": "cartographer.architecture", "title": "Cartographer: Detect Architecture", "icon": "$(layers)" },
      { "command": "cartographer.impact", "title": "Cartographer: Impact Analysis", "icon": "$(warning)" },
      { "command": "cartographer.neighbors", "title": "Cartographer: Show Neighbors", "icon": "$(expand)" },
      { "command": "cartographer.path", "title": "Cartographer: Find Path Between Nodes", "icon": "$(symbol-method)" },
      { "command": "cartographer.similar", "title": "Cartographer: Similar Entities", "icon": "$(files)" },
      { "command": "cartographer.embed", "title": "Cartographer: Generate Embeddings", "icon": "$(wand)" },
      { "command": "cartographer.graph", "title": "Cartographer: Open Graph Visualization", "icon": "$(graph)" },
      { "command": "cartographer.gitIndex", "title": "Cartographer: Index Git History", "icon": "$(git-commit)" },
      { "command": "cartographer.openDb", "title": "Cartographer: Select Database", "icon": "$(folder-opened)" },
      { "command": "cartographer.refresh", "title": "Cartographer: Refresh Views", "icon": "$(refresh)" },
      { "command": "cartographer.watch", "title": "Cartographer: Watch for File Changes", "icon": "$(eye)" },
      { "command": "cartographer.context", "title": "Cartographer: Generate Context Package", "icon": "$(package)" },
      { "command": "cartographer.dbInfo", "title": "Cartographer: Database Info", "icon": "$(database)" }
    ],
    "keybindings": [
      { "key": "ctrl+shift+c i", "command": "cartographer.index" },
      { "key": "ctrl+shift+c s", "command": "cartographer.search" },
      { "key": "ctrl+shift+c a", "command": "cartographer.ask" },
      { "key": "ctrl+shift+c g", "command": "cartographer.graph" },
      { "key": "ctrl+shift+c w", "command": "cartographer.watch" },
      { "key": "ctrl+shift+c d", "command": "cartographer.dbInfo" },
      { "key": "ctrl+shift+c c", "command": "cartographer.context" }
    ],
    "configuration": {
      "title": "Cartographer",
      "properties": {
        "cartographer.dbPath": {
          "type": "string",
          "default": "",
          "description": "Path to Cartographer SQLite database (default: ~/.cartographer/index.db)"
        },
        "cartographer.binPath": {
          "type": "string",
          "default": "cartographer",
          "description": "Path to cartographer CLI binary"
        },
        "cartographer.maxResults": {
          "type": "integer",
          "default": 20,
          "description": "Default max results for search/query"
        },
        "cartographer.autoReindex": {
          "type": "boolean",
          "default": true,
          "description": "Auto re-index the graph when files are saved"
        },
        "cartographer.graphLimit": {
          "type": "integer",
          "default": 400,
          "description": "Max nodes to display in the graph visualization (higher values may be slower)"
        },
        "cartographer.mcpEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Use MCP server for persistent communication (faster than CLI)"
        },
        "cartographer.projectConfig": {
          "type": "string",
          "default": "",
          "description": "Path to project config file (default: .cartographer/config.json in workspace root)"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        { "id": "cartographer", "title": "Cartographer", "icon": "resources/icon.svg" }
      ]
    },
    "views": {
      "cartographer": [
        { "id": "cartographer.repos", "name": "Repository", "icon": "$(repo)" },
        { "id": "cartographer.entities", "name": "Entities by Type", "icon": "$(symbol-class)" },
        { "id": "cartographer.search", "name": "Search Results", "icon": "$(search)" }
      ]
    },
    "menus": {
      "commandPalette": [
        { "command": "cartographer.index", "when": "workspaceFolderCount > 0" },
        { "command": "cartographer.search" },
        { "command": "cartographer.ask" },
        { "command": "cartographer.summarize" },
        { "command": "cartographer.architecture" },
        { "command": "cartographer.impact" },
        { "command": "cartographer.graph" },
        { "command": "cartographer.graphEntityType" },
        { "command": "cartographer.embed" },
        { "command": "cartographer.watch" },
        { "command": "cartographer.context" },
        { "command": "cartographer.dbInfo" }
      ],
      "view/title": [
        { "command": "cartographer.index", "when": "view == cartographer.repos", "group": "navigation" },
        { "command": "cartographer.search", "when": "view == cartographer.search", "group": "navigation" },
        { "command": "cartographer.refresh", "when": "view == cartographer.repos", "group": "navigation@5" }
      ],
      "view/item/context": [
        { "command": "cartographer.graphEntityType", "when": "view == cartographer.entities && viewItem == entityType", "group": "inline" },
        { "command": "cartographer.graph", "when": "view == cartographer.repos", "group": "inline" }
      ],
      "editor/context": [
        { "command": "cartographer.search", "when": "editorHasSelection", "group": "cartographer@1" },
        { "command": "cartographer.impact", "when": "editorHasSelection", "group": "cartographer@2" }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
