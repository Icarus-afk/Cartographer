# ── Cartographer Embedding Configuration ──────────────────────────
# Copy this file to .env and uncomment your preferred model.
# All settings are optional; defaults work well for most CPUs.

# ── Model ─────────────────────────────────────────────────────────
# Best CPU models (fast ↔ accurate):
#   BAAI/bge-small-en-v1.5                   67 MB  384d  Best balance
#   snowflake/snowflake-arctic-embed-xs      90 MB  384d  Retrieval-tuned
#   sentence-transformers/all-MiniLM-L6-v2   90 MB  384d  General purpose
#   jinaai/jina-embeddings-v2-small-en      120 MB  512d  8192-token context
#   jinaai/jina-embeddings-v2-base-code     640 MB  768d  Trained on 30 PLs
#   nomic-ai/nomic-embed-text-v1.5-Q        130 MB  768d  Quantized
#   BAAI/bge-base-en-v1.5                   210 MB  768d  More accurate, slower
#
# CARTOGRAPHER_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Embedding dimension (must match model output dimension)
# CARTOGRAPHER_EMBEDDING_DIM=384

# ── Performance Tuning ────────────────────────────────────────────
# Larger batches use CPU cache better. Tune based on RAM:
#   64   = low-memory (4 GB RAM)
#   256  = default (recommended)
#   512  = high-memory (16+ GB RAM)
# CARTOGRAPHER_EMBEDDING_BATCH_SIZE=256

# CPU parallelism. 0 = auto-detect (uses all cores).
# Set to number of *physical* cores to avoid oversubscription.
# CARTOGRAPHER_EMBEDDING_PARALLELISM=0
